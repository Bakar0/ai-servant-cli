{
  "name": "ai-servant-cli",
  "version": "0.0.1",
  "description": "AI servant CLI — enhances developer and coding-agent workflows.",
  "type": "module",
  "private": true,
  "bin": {
    "servant": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
