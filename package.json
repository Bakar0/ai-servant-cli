    "format": "biome format --write ."
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
